# Used when running the app locally (outside Docker).
# The host is "localhost" because the DB runs on your machine.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/DB_NAME?schema=public"

JWT_SECRET="your_jwt_secret_here"
BCRYPT_SALT_ROUNDS=

# Used by Docker Compose to configure the postgres container and to build
# the DATABASE_URL for the app container. Inside Docker, the app cannot use
# "localhost" to reach the DB — it must use the service name "db" instead.
# docker-compose.yml constructs the URL as:
#   postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
